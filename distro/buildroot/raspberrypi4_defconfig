BR2_aarch64=y
BR2_cortex_a72=y
BR2_TOOLCHAIN_EXTERNAL=y
BR2_INIT_SYSTEMD=y
BR2_ROOTFS_OVERLAY="../../build/rootfs"

# Graphics & Display
BR2_PACKAGE_MESA3D=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_VC4=y
BR2_PACKAGE_WAYLAND=y
BR2_PACKAGE_WAYLAND_PROTOCOLS=y
BR2_PACKAGE_WLROOTS=y
BR2_PACKAGE_LIBINPUT=y
BR2_PACKAGE_SEATD=y

# Audio
BR2_PACKAGE_PIPEWIRE=y
BR2_PACKAGE_ALSA_UTILS=y

# Networking
BR2_PACKAGE_NETWORK_MANAGER=y
BR2_PACKAGE_CURL=y
BR2_PACKAGE_WGET=y
BR2_PACKAGE_DNSMASQ=y
BR2_PACKAGE_DHCP=y

# Web Browser
BR2_PACKAGE_CHROMIUM_BROWSER=y

# Package Management
BR2_PACKAGE_FLATPAK=y

# Python & Development
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_TKINTER=y

# Utilities
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_NANO=y

# System Configuration
BR2_TARGET_GENERIC_HOSTNAME="aurora-pi4"
BR2_TARGET_GENERIC_ISSUE="AuroraOS Raspberry Pi 4"
