[Unit]
Description=AuroraOS Pixel Shell
PartOf=aurora-session.target
After=aurora-compositor.service

[Service]
Type=simple
ExecStart=/usr/bin/aurora-shell
Restart=on-failure
RestartSec=1
Environment=AURORA_ASSET_DIR=/usr/share/aurora/assets
Environment=AURORA_PIXEL_SCALE=2

[Install]
WantedBy=aurora-session.target
