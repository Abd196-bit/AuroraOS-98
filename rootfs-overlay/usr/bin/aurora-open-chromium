#!/bin/sh
set -eu

url="${1:-https://www.google.com}"

for browser in chromium chromium-browser chromium-browser-stable; do
    if command -v "$browser" >/dev/null 2>&1; then
        exec "$browser" \
            --ozone-platform=wayland \
            --enable-features=UseOzonePlatform \
            --class=AuroraChromium \
            "$url"
    fi
done

printf '%s\n' "aurora-open-chromium: Chromium is not installed in this rootfs." >&2
printf '%s\n' "Build the full profile: make full-chromium-image" >&2
exit 127
