#!/bin/sh
set -eu

url="${1:-https://www.mozilla.org/firefox/}"

for browser in firefox firefox-esr; do
    if command -v "$browser" >/dev/null 2>&1; then
        export MOZ_ENABLE_WAYLAND=1
        exec "$browser" "$url"
    fi
done

printf '%s\n' "aurora-open-firefox: Firefox is not installed in this rootfs." >&2
printf '%s\n' "Build the full profile: make full-chromium-image" >&2
exit 127
